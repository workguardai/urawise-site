        <textarea id="audit-frustration" placeholder="e.g. We get traffic but nobody contacts us. Our booking page has high dropout..." style="padding:11px 14px;border:1.5px solid #e4e3f0;border-radius:9px;font-family:'DM Sans',sans-serif;font-size:14px;color:#12111e;background:#fff;outline:none;resize:vertical;min-height:90px;line-height:1.6;"></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;">
        <div style="display:flex;flex-direction:column;gap:6px;">
          <label style="font-size:12px;font-weight:700;color:#5c5b72;letter-spacing:0.5px;text-transform:uppercase;" id="audit-lbl-goal">Main Goal</label>
          <select id="audit-goal" style="padding:11px 14px;border:1.5px solid #e4e3f0;border-radius:9px;font-family:'DM Sans',sans-serif;font-size:14px;color:#12111e;background:#fff;outline:none;cursor:pointer;">
            <option value="">Select goal</option>
            <option value="more leads">More leads / enquiries</option>
            <option value="better Google ranking">Better Google ranking</option>
            <option value="more sales">More online sales</option>
            <option value="better user experience">Better user experience</option>
            <option value="stronger brand">Stronger brand presence</option>
          </select>
