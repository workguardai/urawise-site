<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Urawise — Google Ads & Digital Growth</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
:root{
  --p:#5b47e0;--p2:#4338ca;--acc:#7c3aed;
  --dark:#0d0d14;--surf:#f8f8fc;--surf2:#f0f0f8;
  --white:#ffffff;--ink:#12111e;--dim:#5c5b72;--muted:#9896b0;
  --brd:#e4e3f0;--brd2:rgba(91,71,224,0.14);
  --g:linear-gradient(135deg,#5b47e0,#4338ca);
  --gs:linear-gradient(135deg,#7c3aed,#5b47e0,#4338ca);
}
body{font-family:'DM Sans',sans-serif;background:var(--white);color:var(--ink);font-weight:400;overflow-x:hidden;line-height:1.6}

/* LANG TOGGLE */
.lang-toggle{position:fixed;bottom:28px;right:24px;z-index:999;display:flex;background:rgba(255,255,255,0.97);backdrop-filter:blur(16px);border:1px solid var(--brd);border-radius:40px;padding:4px;box-shadow:0 4px 24px rgba(0,0,0,0.1)}
.lang-btn{display:flex;align-items:center;gap:5px;padding:6px 12px;border-radius:30px;border:none;font-family:'DM Sans',sans-serif;font-size:11px;font-weight:700;cursor:pointer;transition:all 0.22s;background:transparent;color:var(--muted);letter-spacing:0.3px}
.lang-btn.active{background:var(--g);color:#fff;box-shadow:0 2px 10px rgba(91,71,224,0.35)}
.lang-flag{font-size:14px;line-height:1}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 64px;height:70px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,0.95);backdrop-filter:blur(24px);border-bottom:1px solid var(--brd)}
.nav-logo{font-family:'Inter',sans-serif;font-size:21px;font-weight:900;color:var(--ink);letter-spacing:-0.8px}
.nav-logo span{background:var(--g);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.nav-links{display:flex;align-items:center;gap:34px;list-style:none}
.nav-links a{color:var(--dim);text-decoration:none;font-size:14px;font-weight:500;transition:color 0.2s}
.nav-links a:hover{color:var(--ink)}
.nav-cta{background:var(--g)!important;color:#fff!important;padding:9px 20px!important;border-radius:8px!important;font-weight:600!important;font-size:13px!important;box-shadow:0 3px 14px rgba(91,71,224,0.28)!important}

/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;padding:130px 64px 100px;position:relative;overflow:hidden;background:var(--white)}
.hero-bg-shape{position:absolute;top:-80px;right:-120px;width:680px;height:680px;background:radial-gradient(ellipse,rgba(91,71,224,0.07) 0%,transparent 68%);pointer-events:none}
.hero-bg-dots{position:absolute;inset:0;background-image:radial-gradient(rgba(91,71,224,0.06) 1px,transparent 1px);background-size:36px 36px;mask-image:radial-gradient(ellipse 65% 75% at 85% 35%,black 0%,transparent 100%)}
.hero-content{position:relative;max-width:640px;z-index:2}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(91,71,224,0.07);border:1px solid rgba(91,71,224,0.18);border-radius:40px;padding:6px 16px;font-size:11.5px;font-weight:600;color:var(--p);letter-spacing:0.8px;text-transform:uppercase;margin-bottom:28px;animation:fadeUp 0.6s ease both}
.badge-dot{width:7px;height:7px;background:var(--p);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(91,71,224,0.35)}50%{opacity:0.7;box-shadow:0 0 0 6px rgba(91,71,224,0)}}
.hero h1{font-family:'Inter',sans-serif;font-weight:900;font-size:clamp(40px,5vw,68px);line-height:1.05;letter-spacing:-2.5px;margin-bottom:22px;color:var(--ink);animation:fadeUp 0.6s ease 0.1s both}
.hero h1 .grad{background:var(--gs);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero-desc{font-size:17px;color:var(--dim);line-height:1.75;max-width:520px;margin-bottom:7px;font-weight:400;animation:fadeUp 0.6s ease 0.2s both}
.hero-desc2{font-size:14.5px;color:var(--muted);line-height:1.65;max-width:500px;font-weight:400;margin-bottom:44px;animation:fadeUp 0.6s ease 0.25s both}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;animation:fadeUp 0.6s ease 0.3s both}
.btn-grad{display:inline-flex;align-items:center;gap:8px;background:var(--g);color:#fff;text-decoration:none;padding:14px 28px;border-radius:10px;font-size:14.5px;font-weight:600;transition:all 0.22s;box-shadow:0 4px 20px rgba(91,71,224,0.28)}
.btn-grad:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(91,71,224,0.4)}
.btn-outline{display:inline-flex;align-items:center;gap:8px;background:transparent;color:var(--dim);text-decoration:none;padding:14px 26px;border-radius:10px;font-size:14.5px;font-weight:500;transition:all 0.22s;border:1.5px solid var(--brd)}
.btn-outline:hover{color:var(--ink);border-color:rgba(91,71,224,0.35)}
.hero-float{position:absolute;right:64px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:14px;z-index:2;animation:fadeUp 0.6s ease 0.4s both}
.float-card{background:var(--white);border:1.5px solid var(--brd);border-radius:14px;padding:20px 24px;min-width:196px;transition:all 0.25s;box-shadow:0 4px 20px rgba(0,0,0,0.06);position:relative;overflow:hidden}
.float-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--g)}
.float-card:hover{transform:translateX(-5px);border-color:rgba(91,71,224,0.3);box-shadow:0 8px 32px rgba(91,71,224,0.1)}
.float-num{font-family:'Inter',sans-serif;font-weight:900;font-size:32px;letter-spacing:-1px;line-height:1;background:var(--g);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:4px}
.float-label{font-size:11.5px;color:var(--muted);font-weight:500}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

/* TICKER */
.ticker{background:var(--surf);border-top:1.5px solid var(--brd);border-bottom:1.5px solid var(--brd);padding:15px 0;overflow:hidden}
.ticker-track{display:flex;animation:ticker 28s linear infinite;width:max-content}
.ticker-item{display:inline-flex;align-items:center;gap:8px;padding:0 40px;font-size:11.5px;font-weight:600;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;white-space:nowrap}
.tdot{width:5px;height:5px;background:var(--p);border-radius:50%;opacity:0.5}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* LAYOUT */
.container{max-width:1140px;margin:0 auto;padding:0 64px}
.section{padding:96px 0}
.bg-surf{background:var(--surf);border-top:1.5px solid var(--brd);border-bottom:1.5px solid var(--brd)}

/* SECTION LABELS */
.stag{display:inline-flex;align-items:center;gap:8px;font-size:10.5px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--p);margin-bottom:14px}
.stag::before{content:'';width:20px;height:2px;background:var(--g);border-radius:2px}
h2{font-family:'Inter',sans-serif;font-weight:900;font-size:clamp(30px,3.8vw,48px);letter-spacing:-2px;line-height:1.06;margin-bottom:14px;color:var(--ink)}
.sdesc{font-size:16px;color:var(--dim);line-height:1.75;max-width:540px;font-weight:400;margin-bottom:6px}
.sdesc2{font-size:14px;color:var(--muted);max-width:500px;margin-bottom:52px;font-weight:400;font-style:italic}

/* SERVICES */
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:52px}
.svc-card{background:var(--white);border:1.5px solid var(--brd);border-radius:16px;padding:30px 26px;transition:all 0.25s;position:relative;overflow:hidden}
.svc-card::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--g);opacity:0;transition:opacity 0.25s}
.svc-card:hover{border-color:rgba(91,71,224,0.3);transform:translateY(-5px);box-shadow:0 16px 48px rgba(91,71,224,0.1)}
.svc-card:hover::after{opacity:1}
.svc-icon{width:48px;height:48px;background:rgba(91,71,224,0.07);border:1.5px solid rgba(91,71,224,0.14);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:16px}
.svc-card h3{font-family:'Inter',sans-serif;font-size:16px;font-weight:800;letter-spacing:-0.3px;margin-bottom:3px;color:var(--ink)}
.svc-sub{font-size:12px;color:var(--muted);font-style:italic;margin-bottom:11px}
.svc-card p{font-size:13.5px;color:var(--dim);line-height:1.7;font-weight:400}
.svc-pill{display:inline-block;background:rgba(91,71,224,0.08);color:var(--p);font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;margin-top:14px;letter-spacing:0.5px}

/* GOOGLE ADS DEEP SECTION */
.ads-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start}
.ads-tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:28px}
.ads-tag{background:var(--white);border:1.5px solid var(--brd);border-radius:8px;padding:8px 14px;font-size:12.5px;font-weight:600;color:var(--dim);transition:all 0.2s;cursor:default}
.ads-tag:hover{border-color:var(--p);color:var(--p);background:rgba(91,71,224,0.04)}
.ads-tag.key{background:rgba(91,71,224,0.07);border-color:rgba(91,71,224,0.2);color:var(--p)}
.ads-features{display:flex;flex-direction:column;gap:16px;margin-top:8px}
.ads-feat{display:flex;gap:14px;align-items:flex-start;padding:18px 20px;background:var(--white);border:1.5px solid var(--brd);border-radius:12px;transition:all 0.22s}
.ads-feat:hover{border-color:rgba(91,71,224,0.3);box-shadow:0 4px 20px rgba(91,71,224,0.08)}
.ads-feat-icon{width:40px;height:40px;background:rgba(91,71,224,0.07);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.ads-feat h4{font-size:14px;font-weight:700;margin-bottom:3px;color:var(--ink)}
.ads-feat p{font-size:12.5px;color:var(--dim);line-height:1.6}

/* PACKAGES / TIERS */
.pkg-intro{text-align:center;max-width:580px;margin:0 auto 56px}
.pkg-intro .sdesc{margin:0 auto}
.pkg-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.pkg-card{background:var(--white);border:1.5px solid var(--brd);border-radius:18px;padding:32px 28px;display:flex;flex-direction:column;transition:all 0.25s;position:relative;overflow:hidden}
.pkg-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--brd)}
.pkg-card.featured{border-color:rgba(91,71,224,0.35);box-shadow:0 8px 40px rgba(91,71,224,0.12)}
.pkg-card.featured::before{background:var(--g)}
.pkg-badge{display:inline-block;background:var(--g);color:#fff;font-size:9.5px;font-weight:700;padding:3px 10px;border-radius:20px;letter-spacing:1px;text-transform:uppercase;margin-bottom:16px;align-self:flex-start}
.pkg-card h3{font-family:'Inter',sans-serif;font-size:20px;font-weight:900;letter-spacing:-0.5px;margin-bottom:6px;color:var(--ink)}
.pkg-card .pkg-sub{font-size:13px;color:var(--muted);margin-bottom:22px;min-height:40px;line-height:1.55}
.pkg-divider{height:1px;background:var(--brd);margin-bottom:20px}
.pkg-includes{font-size:10.5px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
.pkg-list{list-style:none;display:flex;flex-direction:column;gap:9px;flex:1;margin-bottom:24px}
.pkg-list li{display:flex;align-items:flex-start;gap:10px;font-size:13.5px;color:var(--dim);line-height:1.5}
.pkg-list li::before{content:'✓';font-size:11px;font-weight:800;color:var(--p);background:rgba(91,71,224,0.08);width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.pkg-list li.dim-item{color:var(--muted)}
.pkg-list li.dim-item::before{color:var(--muted);background:rgba(0,0,0,0.04)}
.pkg-cta{display:flex;align-items:center;justify-content:center;gap:8px;background:var(--surf);border:1.5px solid var(--brd);color:var(--dim);text-decoration:none;padding:13px;border-radius:10px;font-size:13.5px;font-weight:600;transition:all 0.22s;margin-top:auto}
.pkg-cta:hover{border-color:var(--p);color:var(--p);background:rgba(91,71,224,0.04)}
.pkg-card.featured .pkg-cta{background:var(--g);border-color:transparent;color:#fff;box-shadow:0 4px 16px rgba(91,71,224,0.25)}
.pkg-card.featured .pkg-cta:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(91,71,224,0.38)}
.pkg-note{text-align:center;margin-top:28px;font-size:13px;color:var(--muted)}
.pkg-note a{color:var(--p);text-decoration:none;font-weight:600}

/* PROCESS */
.proc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0;margin-top:52px;position:relative}
.proc-grid::before{content:'';position:absolute;top:22px;left:12.5%;right:12.5%;height:1.5px;background:linear-gradient(90deg,var(--p),rgba(91,71,224,0.1));z-index:0}
.proc-step{text-align:center;padding:0 8px;position:relative;z-index:1}
.proc-c{width:44px;height:44px;background:var(--g);border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Inter',sans-serif;font-size:15px;font-weight:900;color:#fff;margin:0 auto 12px;box-shadow:0 4px 16px rgba(91,71,224,0.28);border:3px solid var(--white)}
.proc-tag{font-size:9.5px;font-weight:700;color:var(--p);letter-spacing:0.5px;margin-bottom:5px;text-transform:uppercase}
.proc-t{font-size:13.5px;font-weight:700;margin-bottom:5px;color:var(--ink)}
.proc-d{font-size:12px;color:var(--muted);font-weight:400;line-height:1.5}

/* WHY */
.why-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:52px}
.why-card{background:var(--white);border:1.5px solid var(--brd);border-radius:14px;padding:26px 20px;transition:all 0.25s}
.why-card:hover{border-color:rgba(91,71,224,0.28);transform:translateY(-4px);box-shadow:0 12px 36px rgba(91,71,224,0.08)}
.why-num{font-family:'Inter',sans-serif;font-size:46px;font-weight:900;letter-spacing:-2px;background:linear-gradient(135deg,rgba(91,71,224,0.14),rgba(67,56,202,0.06));-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1;margin-bottom:12px}
.why-card h4{font-size:14.5px;font-weight:700;margin-bottom:7px;color:var(--ink)}
.why-card p{font-size:13px;color:var(--dim);line-height:1.65;font-weight:400}

/* CONTACT */
.contact-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:72px;align-items:center}
.contact-box{background:var(--white);border:1.5px solid var(--brd);border-radius:18px;padding:36px;display:flex;flex-direction:column;gap:20px;box-shadow:0 4px 32px rgba(0,0,0,0.06)}
.c-row{display:flex;gap:16px;align-items:center}
.c-icon{width:46px;height:46px;background:rgba(91,71,224,0.07);border:1.5px solid rgba(91,71,224,0.14);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.c-label{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--p);margin-bottom:2px}
.c-val{font-size:14.5px;font-weight:700;color:var(--ink)}
.c-hint{font-size:11.5px;color:var(--muted);font-style:italic;margin-top:1px}
.c-div{height:1.5px;background:var(--brd)}
.wa-btn{display:flex;align-items:center;justify-content:center;gap:10px;background:linear-gradient(135deg,#25D366,#128C7E);color:#fff;text-decoration:none;padding:16px;border-radius:12px;font-size:15px;font-weight:700;transition:all 0.22s;box-shadow:0 4px 18px rgba(37,211,102,0.2)}
.wa-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(37,211,102,0.35)}

/* FOOTER */
footer{padding:32px 64px;border-top:1.5px solid var(--brd);display:flex;align-items:center;justify-content:space-between;background:var(--white)}
.f-logo{font-family:'Inter',sans-serif;font-weight:900;font-size:18px;letter-spacing:-0.5px;color:var(--ink)}
.f-logo span{background:var(--g);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.f-copy{font-size:12.5px;color:var(--muted);font-weight:400}
.f-langs{display:flex;gap:6px}
.f-chip{background:var(--surf);border:1.5px solid var(--brd);color:var(--dim);font-size:10.5px;font-weight:700;padding:4px 10px;border-radius:20px;letter-spacing:0.3px}

/* REVEAL */
.reveal{opacity:0;transform:translateY(16px);transition:opacity 0.5s ease,transform 0.5s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

@media(max-width:900px){
  nav{padding:0 24px}.nav-links{display:none}
  .hero{padding:100px 24px 80px}.hero-float{display:none}
  .container{padding:0 24px}.section{padding:72px 0}
  .svc-grid,.why-grid,.pkg-grid{grid-template-columns:1fr}
  .ads-grid,.contact-grid{grid-template-columns:1fr;gap:40px}
  .proc-grid{grid-template-columns:1fr 1fr;gap:24px}.proc-grid::before{display:none}
  footer{padding:24px;flex-direction:column;gap:14px;text-align:center}
}
</style>
</head>
<body>

<div class="lang-toggle">
  <button class="lang-btn active" onclick="setLang('en')" data-lang="en"><span class="lang-flag">🇬🇧</span> EN</button>
  <button class="lang-btn" onclick="setLang('es')" data-lang="es"><span class="lang-flag">🇪🇸</span> ES</button>
  <button class="lang-btn" onclick="setLang('sq')" data-lang="sq"><span class="lang-flag">🇦🇱</span> SQ</button>
  <button class="lang-btn" onclick="setLang('da')" data-lang="da"><span class="lang-flag">🇩🇰</span> DA</button>
</div>

<nav>
  <div class="nav-logo">Ura<span>wise</span></div>
  <ul class="nav-links">
    <li><a href="#services" data-en="Services" data-es="Servicios" data-sq="Shërbime" data-da="Tjenester">Services</a></li>
    <li><a href="#ads" data-en="Google Ads" data-es="Google Ads" data-sq="Google Ads" data-da="Google Ads">Google Ads</a></li>
    <li><a href="#packages" data-en="Packages" data-es="Paquetes" data-sq="Paketat" data-da="Pakker">Packages</a></li>
    <li><a href="#tools" data-en="Free Tools" data-es="Herramientas" data-sq="Mjetet" data-da="Gratis Værktøjer">Free Tools</a></li>
    <li><a href="#contact" class="nav-cta" data-en="Book Free Audit" data-es="Auditoría Gratis" data-sq="Auditim Falas" data-da="Gratis Analyse">Book Free Audit</a></li>
  </ul>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="hero-bg-shape"></div>
  <div class="hero-bg-dots"></div>
  <div class="hero-content">
    <div class="hero-badge"><div class="badge-dot"></div><span data-en="Google Ads · Digital Growth · Barcelona" data-es="Google Ads · Crecimiento Digital · Barcelona" data-sq="Google Ads · Rritje Dixhitale · Barcelona" data-da="Google Ads · Digital Vækst · Barcelona">Google Ads · Digital Growth · Barcelona</span></div>
    <h1><span data-en="Turn ad spend into" data-es="Convierte tu inversión en" data-sq="Ktheje buxhetin e reklamave në" data-da="Gør annoncekroner til">Turn ad spend into</span><br><span class="grad" data-en="real customers." data-es="clientes reales." data-sq="klientë realë." data-da="rigtige kunder.">real customers.</span></h1>
    <p class="hero-desc" data-en="We manage Google Ads campaigns and build digital presence that drives qualified leads — not just clicks. Based in Barcelona, serving clients across Europe and worldwide." data-es="Gestionamos campañas de Google Ads y construimos presencia digital que genera contactos cualificados. Basados en Barcelona, servimos a clientes en toda Europa y el mundo." data-sq="Ne menaxhojmë fushatat Google Ads dhe ndërtojmë prezencë dixhitale që gjeneron kontakte të kualifikuara. Bazuar në Barcelona, shërbejmë klientë në të gjithë Europën dhe botën." data-da="Vi administrerer Google Ads-kampagner og bygger digital tilstedeværelse der genererer kvalificerede leads. Baseret i Barcelona, betjener kunder over hele Europa og verden.">We manage Google Ads campaigns and build digital presence that drives qualified leads — not just clicks. Based in Barcelona, serving clients across Europe and worldwide.</p>
    <p class="hero-desc2" data-en="Danish · Albanian · English · Spanish · Italian — no language barriers, anywhere." data-es="Danés · Albanés · Inglés · Español · Italiano — sin barreras idiomáticas, en cualquier lugar." data-sq="Danisht · Shqip · Anglisht · Spanjisht · Italisht — pa barriera gjuhësore, kudo." data-da="Dansk · Albansk · Engelsk · Spansk · Italiensk — ingen sprogbarrierer, overalt.">Danish · Albanian · English · Spanish · Italian — no language barriers, anywhere.</p>
    <div class="hero-btns">
