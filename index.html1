    <button id="tab-forecast" onclick="switchTool('forecast')" style="display:flex;align-items:center;gap:8px;padding:13px 22px;border:none;background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.45);font-family:'DM Sans',sans-serif;font-size:13.5px;font-weight:700;cursor:pointer;border-radius:10px 10px 0 0;border-bottom:3px solid transparent;transition:all 0.2s;">
