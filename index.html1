          <input id="audit-business" type="text" placeholder="e.g. Restaurant, Law firm, Online shop" style="padding:11px 14px;border:1.5px solid #e4e3f0;border-radius:9px;font-family:'DM Sans',sans-serif;font-size:14px;color:#12111e;background:#fff;outline:none;">
        </div>
