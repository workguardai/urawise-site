  <!-- PANEL: SEO RANKING ANALYSER -->
  <div id="panel-ranking" style="display:none;padding:52px 0 72px;">
    <div style="max-width:820px;margin:0 auto;padding:0 24px;">

      <!-- TWO PART INTRO -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:28px;">

        <!-- Part 1 card -->
        <div style="background:#fff;border:1.5px solid #e4e3f0;border-radius:14px;padding:22px;position:relative;overflow:hidden;">
          <div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(135deg,#5b47e0,#4338ca);"></div>
          <div style="font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#5b47e0;margin-bottom:8px;">PART 1 — FREE, NO LOGIN</div>
          <h4 style="font-size:16px;font-weight:800;color:#12111e;margin-bottom:6px;" id="rank-p1-title">Live Technical Audit</h4>
          <p style="font-size:13px;color:#5c5b72;line-height:1.6;" id="rank-p1-desc">Real data from Google's PageSpeed API — Core Web Vitals, mobile score, page speed, SEO errors. No login needed.</p>
        </div>

        <!-- Part 2 card -->
        <div style="background:#fff;border:1.5px solid #e4e3f0;border-radius:14px;padding:22px;position:relative;overflow:hidden;">
          <div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(135deg,#10b981,#059669);"></div>
          <div style="font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#059669;margin-bottom:8px;">PART 2 — CONNECT GOOGLE</div>
          <h4 style="font-size:16px;font-weight:800;color:#12111e;margin-bottom:6px;" id="rank-p2-title">Real Ranking Positions</h4>
          <p style="font-size:13px;color:#5c5b72;line-height:1.6;" id="rank-p2-desc">Connect your Google Search Console to see your actual keyword positions, clicks, impressions and why you rank where you do.</p>
        </div>
      </div>

      <!-- ═══ PART 1: TECHNICAL AUDIT ═══ -->
      <div style="background:#fff;border:1.5px solid #e4e3f0;border-radius:16px;overflow:hidden;margin-bottom:28px;">
        <div style="padding:20px 24px;border-bottom:1.5px solid #e4e3f0;background:rgba(91,71,224,0.04);display:flex;align-items:center;gap:10px;">
          <div style="width:32px;height:32px;background:linear-gradient(135deg,#5b47e0,#4338ca);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;">⚡</div>
          <div>
            <div style="font-size:14px;font-weight:800;color:#12111e;" id="rank-audit-heading">Part 1 — Live Technical Audit</div>
            <div style="font-size:12px;color:#9896b0;" id="rank-audit-sub">Powered by Google PageSpeed Insights API</div>
          </div>
        </div>
        <div style="padding:22px 24px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px;">
            <div style="display:flex;flex-direction:column;gap:6px;">
              <label style="font-size:11px;font-weight:700;color:#5c5b72;letter-spacing:0.5px;text-transform:uppercase;" id="rank-lbl-url">Website URL</label>
              <input id="rank-url" type="text" placeholder="https://yourwebsite.com" style="padding:11px 14px;border:1.5px solid #e4e3f0;border-radius:9px;font-family:'DM Sans',sans-serif;font-size:14px;color:#12111e;background:#f8f8fc;outline:none;">
            </div>
            <div style="display:flex;flex-direction:column;gap:6px;">
              <label style="font-size:11px;font-weight:700;color:#5c5b72;letter-spacing:0.5px;text-transform:uppercase;" id="rank-lbl-kw">Target Keywords</label>
              <input id="rank-keywords" type="text" placeholder="e.g. dentist Barcelona, dental clinic" style="padding:11px 14px;border:1.5px solid #e4e3f0;border-radius:9px;font-family:'DM Sans',sans-serif;font-size:14px;color:#12111e;background:#f8f8fc;outline:none;">
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px;">
            <div style="display:flex;flex-direction:column;gap:6px;">
              <label style="font-size:11px;font-weight:700;color:#5c5b72;letter-spacing:0.5px;text-transform:uppercase;" id="rank-lbl-biz">Business Type</label>
              <input id="rank-business" type="text" placeholder="e.g. Dental clinic, Restaurant" style="padding:11px 14px;border:1.5px solid #e4e3f0;border-radius:9px;font-family:'DM Sans',sans-serif;font-size:14px;color:#12111e;background:#f8f8fc;outline:none;">
            </div>
            <div style="display:flex;flex-direction:column;gap:6px;">
              <label style="font-size:11px;font-weight:700;color:#5c5b72;letter-spacing:0.5px;text-transform:uppercase;" id="rank-lbl-market">Target Market</label>
              <select id="rank-market" style="padding:11px 14px;border:1.5px solid #e4e3f0;border-radius:9px;font-family:'DM Sans',sans-serif;font-size:14px;color:#12111e;background:#f8f8fc;outline:none;cursor:pointer;">
                <option value="">Select market</option>
                <option value="Spain / Spanish">Spain / Spanish</option>
                <option value="Denmark / Danish">Denmark / Danish</option>
                <option value="UK / English">UK / English</option>
                <option value="Albania / Albanian">Albania / Albanian</option>
                <option value="International / English">International</option>
              </select>
            </div>
          </div>
          <button id="ranking-btn" onclick="runRankingAnalysis()" style="width:100%;display:flex;align-items:center;justify-content:center;gap:10px;background:linear-gradient(135deg,#5b47e0,#4338ca);color:#fff;border:none;padding:14px 32px;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:700;cursor:pointer;box-shadow:0 4px 18px rgba(91,71,224,0.28);">
            <span id="ranking-btn-text">⚡ Run Live Technical Audit</span>
          </button>
        </div>

        <!-- PART 1 RESULTS -->
        <div id="ranking-result" style="display:none;border-top:1.5px solid #e4e3f0;">
          <!-- Score cards -->
          <div id="ranking-score-cards" style="display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:#e4e3f0;border-bottom:1.5px solid #e4e3f0;"></div>
          <!-- AI analysis output -->
          <div id="ranking-output" style="padding:24px;font-size:14px;color:#5c5b72;line-height:1.75;white-space:pre-wrap;max-height:480px;overflow-y:auto;"></div>
          <!-- Chat follow-up -->
          <div id="ranking-chat-area"></div>
          <!-- Upgrade -->
          <div style="background:rgba(91,71,224,0.04);border-top:1.5px solid rgba(91,71,224,0.1);padding:16px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
            <span style="font-size:13px;color:#5c5b72;" id="rank-upgrade-text"><strong>Want us to fix these issues for you?</strong> We handle technical SEO, speed optimisation and content improvements.</span>
            <a href="#contact" style="display:inline-flex;align-items:center;gap:7px;background:linear-gradient(135deg,#5b47e0,#4338ca);color:#fff;text-decoration:none;padding:9px 18px;border-radius:8px;font-size:13px;font-weight:700;">📈 Fix My SEO →</a>
          </div>
        </div>
      </div>

      <!-- ═══ PART 2: SEARCH CONSOLE ═══ -->
      <div style="background:#fff;border:1.5px solid #e4e3f0;border-radius:16px;overflow:hidden;">
        <div style="padding:20px 24px;border-bottom:1.5px solid #e4e3f0;background:rgba(16,185,129,0.04);display:flex;align-items:center;gap:10px;">
          <div style="width:32px;height:32px;background:linear-gradient(135deg,#10b981,#059669);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;">📊</div>
          <div>
            <div style="font-size:14px;font-weight:800;color:#12111e;" id="rank-gsc-heading">Part 2 — Real Google Ranking Data</div>
            <div style="font-size:12px;color:#9896b0;" id="rank-gsc-sub">Connect Google Search Console to see your actual keyword positions</div>
          </div>
        </div>
        <div id="gsc-panel" style="padding:28px 24px;text-align:center;">
          <div style="font-size:42px;margin-bottom:14px;">🔍</div>
          <h4 style="font-size:18px;font-weight:800;color:#12111e;margin-bottom:8px;" id="gsc-connect-title">See Your Real Google Rankings</h4>
          <p style="font-size:14px;color:#5c5b72;max-width:480px;margin:0 auto 22px;line-height:1.65;" id="gsc-connect-desc">Connect your Google Search Console account to see exactly which keywords you rank for, your real positions, clicks and impressions. Claude then explains what the data means and how to improve it.</p>
          <div style="background:#fafafa;border:1.5px solid #e4e3f0;border-radius:10px;padding:14px 18px;margin-bottom:22px;font-size:12.5px;color:#9896b0;text-align:left;line-height:1.6;" id="gsc-privacy-note">🔒 <strong style="color:#5c5b72;">Privacy:</strong> We only read your Search Console data. We never store it. Data is used only to generate your analysis and then discarded.</div>
          <button id="gsc-connect-btn" onclick="connectSearchConsole()" style="display:inline-flex;align-items:center;gap:10px;background:#fff;border:1.5px solid #e4e3f0;border-radius:10px;padding:14px 24px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:700;color:#12111e;cursor:pointer;transition:all 0.2s;box-shadow:0 2px 12px rgba(0,0,0,0.06);">
            <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            <span id="gsc-btn-label">Connect Google Search Console</span>
          </button>
        </div>

        <!-- GSC results appear here after auth -->
        <div id="gsc-results" style="display:none;">
          <div style="padding:20px 24px;border-top:1.5px solid #e4e3f0;border-bottom:1.5px solid #e4e3f0;background:#fafafa;display:flex;align-items:center;justify-content:space-between;">
            <span style="font-size:13px;font-weight:700;color:#059669;">✅ <span id="gsc-connected-site">Connected</span></span>
            <button onclick="disconnectGSC()" style="font-size:12px;color:#9896b0;background:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;" id="gsc-disconnect-btn">Disconnect</button>
          </div>
          <!-- Keyword ranking table -->
          <div id="gsc-table-wrap" style="padding:20px 24px;overflow-x:auto;"></div>
          <!-- AI analysis of GSC data -->
          <div id="gsc-analysis-wrap" style="padding:0 24px 20px;"></div>
          <!-- Chat follow-up for GSC -->
          <div id="gsc-chat-area"></div>
          <div style="background:rgba(16,185,129,0.04);border-top:1.5px solid rgba(16,185,129,0.15);padding:16px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
            <span style="font-size:13px;color:#5c5b72;" id="gsc-upgrade-text"><strong>Want expert help improving these rankings?</strong> We analyse your full Search Console data and build a ranking improvement plan.</span>
            <a href="#contact" style="display:inline-flex;align-items:center;gap:7px;background:linear-gradient(135deg,#10b981,#059669);color:#fff;text-decoration:none;padding:9px 18px;border-radius:8px;font-size:13px;font-weight:700;">📈 Get a Ranking Plan →</a>
          </div>
        </div>
      </div>

    </div>
  </div>

</div><!-- /panels -->
</div><!-- /tools -->

